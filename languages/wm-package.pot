msgid "Short codes:"
msgstr ""

msgid "Track page:"
msgstr ""

msgid "Shortcode to display a single track with full details, map, and related POIs."
msgstr ""

msgid "Parameters:"
msgstr ""

msgid "(Required) The ID of the track to display."
msgstr ""

msgid "(Optional) Comma-separated list of layer IDs for track navigation (Previous/Next buttons)."
msgstr ""

msgid "POI page:"
msgstr ""

msgid "Shortcode to display a single Point of Interest (POI) with full details and map location."
msgstr ""

msgid "(Required) The ID of the POI to display."
msgstr ""

msgid "Grid Tracks page:"
msgstr ""

msgid "Shortcode to display a grid of tracks with optional filters (distance, region, difficulty, elevation). Uses Elasticsearch API for advanced filtering."
msgstr ""

msgid "(Optional) ID of a single layer to display tracks from."
msgstr ""

msgid "(Optional) Comma-separated list of layer IDs. Takes precedence over layer_id if both are provided."
msgstr ""

msgid "(Optional) Maximum number of tracks to display. Default: -1 (unlimited)."
msgstr ""

msgid "(Optional) Display tracks in random order. Values: \"true\" or \"false\". Default: \"false\"."
msgstr ""

msgid "(Optional) Display layer content (title, subtitle, description, featured image). Values: true/false. Default: false."
msgstr ""

msgid "(Optional) Use Elasticsearch API for advanced filtering. Values: \"true\" or \"false\". Default: \"true\"."
msgstr ""

msgid "(Optional) Show filter interface (distance, region, difficulty, elevation). Values: \"true\" or \"false\". Default: \"true\"."
msgstr ""

msgid "Grid POIs page:"
msgstr ""

msgid "Shortcode to display a grid of POIs filtered by POI type taxonomy."
msgstr ""

msgid "(Optional) ID of a single POI type to display POIs from."
msgstr ""

msgid "(Optional) Comma-separated list of POI type IDs. Takes precedence over poi_type_id if both are provided."
msgstr ""

msgid "(Optional) Maximum number of POIs to display. Default: -1 (unlimited)."
msgstr ""

msgid "(Optional) Display POIs in random order. Values: \"true\" or \"false\". Default: \"false\"."
msgstr ""

