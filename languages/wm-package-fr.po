msgstr "Fichiers PNG uniquement. L'image remplacera l'actuelle."

msgid "Short codes:"
msgstr "Shortcodes :"

msgid "Track page:"
msgstr "Page itinéraire :"

msgid "Shortcode to display a single track with full details, map, and related POIs."
msgstr "Shortcode pour afficher un itinéraire avec détails, carte et POI associés."

msgid "Parameters:"
msgstr "Paramètres :"

msgid "(Required) The ID of the track to display."
msgstr "(Requis) ID de l'itinéraire à afficher."

msgid "(Optional) Comma-separated list of layer IDs for track navigation (Previous/Next buttons)."
msgstr "(Optionnel) Liste d'ID de layers séparés par des virgules pour la navigation (Précédent/Suivant)."

msgid "POI page:"
msgstr "Page POI :"

msgid "Shortcode to display a single Point of Interest (POI) with full details and map location."
msgstr "Shortcode pour afficher un POI avec détails et position sur la carte."

msgid "(Required) The ID of the POI to display."
msgstr "(Requis) ID du POI à afficher."

msgid "Grid Tracks page:"
msgstr "Page grille itinéraires :"

msgid "Shortcode to display a grid of tracks with optional filters (distance, region, difficulty, elevation). Uses Elasticsearch API for advanced filtering."
msgstr "Shortcode pour une grille d'itinéraires avec filtres optionnels (distance, région, difficulté, dénivelé). Utilise l'API Elasticsearch."

msgid "(Optional) ID of a single layer to display tracks from."
msgstr "(Optionnel) ID d'un layer pour afficher les itinéraires."

msgid "(Optional) Comma-separated list of layer IDs. Takes precedence over layer_id if both are provided."
msgstr "(Optionnel) Liste d'ID de layers. Prioritaire sur layer_id si les deux sont fournis."

msgid "(Optional) Maximum number of tracks to display. Default: -1 (unlimited)."
msgstr "(Optionnel) Nombre max d'itinéraires à afficher. Par défaut : -1 (illimité)."

msgid "(Optional) Display tracks in random order. Values: \"true\" or \"false\". Default: \"false\"."
msgstr "(Optionnel) Afficher les itinéraires dans un ordre aléatoire. Valeurs : \"true\" ou \"false\". Par défaut : \"false\"."

msgid "(Optional) Display layer content (title, subtitle, description, featured image). Values: true/false. Default: false."
msgstr "(Optionnel) Afficher le contenu du layer (titre, sous-titre, description, image). Valeurs : true/false. Par défaut : false."

msgid "(Optional) Use Elasticsearch API for advanced filtering. Values: \"true\" or \"false\". Default: \"true\"."
msgstr "(Optionnel) Utiliser l'API Elasticsearch pour le filtrage. Valeurs : \"true\" ou \"false\". Par défaut : \"true\"."

msgid "(Optional) Show filter interface (distance, region, difficulty, elevation). Values: \"true\" or \"false\". Default: \"true\"."
msgstr "(Optionnel) Afficher l'interface de filtres (distance, région, difficulté, dénivelé). Valeurs : \"true\" ou \"false\". Par défaut : \"true\"."

msgid "Grid POIs page:"
msgstr "Page grille POI :"

msgid "Shortcode to display a grid of POIs filtered by POI type taxonomy."
msgstr "Shortcode pour une grille de POI filtrés par type."

msgid "(Optional) ID of a single POI type to display POIs from."
msgstr "(Optionnel) ID d'un type de POI pour afficher les POI."

msgid "(Optional) Comma-separated list of POI type IDs. Takes precedence over poi_type_id if both are provided."
msgstr "(Optionnel) Liste d'ID de types POI. Prioritaire sur poi_type_id si les deux sont fournis."

msgid "(Optional) Maximum number of POIs to display. Default: -1 (unlimited)."
msgstr "(Optionnel) Nombre max de POI à afficher. Par défaut : -1 (illimité)."

msgid "(Optional) Display POIs in random order. Values: \"true\" or \"false\". Default: \"false\"."
msgstr "(Optionnel) Afficher les POI dans un ordre aléatoire. Valeurs : \"true\" ou \"false\". Par défaut : \"false\"."

