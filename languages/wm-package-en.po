msgid "Tracks list API"
msgstr "Tracks list API"

msgid "API endpoint used to retrieve the list of tracks for a specific app."
msgstr "API endpoint used to retrieve the list of tracks for a specific app."

msgid "Layer API"
msgstr "Layer API"

msgid "API endpoint used to retrieve layer information including tracks, metadata, and content for grid displays."
msgstr "API endpoint used to retrieve layer information including tracks, metadata, and content for grid displays."

msgid "Single Track API"
msgstr "Single Track API"

msgid "API endpoint used to retrieve detailed information for a single track by ID."
msgstr "API endpoint used to retrieve detailed information for a single track by ID."

msgid "POI API"
msgstr "POI API"

msgid "API endpoint used to retrieve Points of Interest (POI) data in GeoJSON format for a specific app."
msgstr "API endpoint used to retrieve Points of Interest (POI) data in GeoJSON format for a specific app."

msgid "POI Type API"
msgstr "POI Type API"

msgid "API endpoint used to retrieve POI type taxonomies for filtering and categorizing Points of Interest."
msgstr "API endpoint used to retrieve POI type taxonomies for filtering and categorizing Points of Interest."

msgid "Elasticsearch API"
msgstr "Elasticsearch API"

msgid "Elasticsearch API used for advanced track filtering and search in grid views."
msgstr "Elasticsearch API used for advanced track filtering and search in grid views."

msgid "Config API"
msgstr "Config API"

msgid "Config JSON used for this app (shard + APP ID). Source for WORDPRESS/APP options when \"Refresh Config API\" is used."
msgstr "Config JSON used for this app (shard + APP ID). Source for WORDPRESS/APP options when \"Refresh Config API\" is used."

msgid "Links:"
msgstr "Links:"

msgid "Configure the URLs used for the dynamic redirect: on desktop the link opens the Website URL, on iOS the iOS App URL (App Store), on Android the Android App URL (Play Store). Add the CSS class below to any element (menu item, link, button, or container) to enable this redirect."
msgstr "Configure the URLs used for the dynamic redirect: on desktop the link opens the Website URL, on iOS the iOS App URL (App Store), on Android the Android App URL (Play Store). Add the CSS class below to any element (menu item, link, button, or container) to enable this redirect."

