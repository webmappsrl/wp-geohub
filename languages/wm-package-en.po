msgid "Short codes:"
msgstr "Short codes:"

msgid "Track page:"
msgstr "Track page:"

msgid "Shortcode to display a single track with full details, map, and related POIs."
msgstr "Shortcode to display a single track with full details, map, and related POIs."

msgid "Parameters:"
msgstr "Parameters:"

msgid "(Required) The ID of the track to display."
msgstr "(Required) The ID of the track to display."

msgid "(Optional) Comma-separated list of layer IDs for track navigation (Previous/Next buttons)."
msgstr "(Optional) Comma-separated list of layer IDs for track navigation (Previous/Next buttons)."

msgid "POI page:"
msgstr "POI page:"

msgid "Shortcode to display a single Point of Interest (POI) with full details and map location."
msgstr "Shortcode to display a single Point of Interest (POI) with full details and map location."

msgid "(Required) The ID of the POI to display."
msgstr "(Required) The ID of the POI to display."

msgid "Grid Tracks page:"
msgstr "Grid Tracks page:"

msgid "Shortcode to display a grid of tracks with optional filters (distance, region, difficulty, elevation). Uses Elasticsearch API for advanced filtering."
msgstr "Shortcode to display a grid of tracks with optional filters (distance, region, difficulty, elevation). Uses Elasticsearch API for advanced filtering."

msgid "(Optional) ID of a single layer to display tracks from."
msgstr "(Optional) ID of a single layer to display tracks from."

msgid "(Optional) Comma-separated list of layer IDs. Takes precedence over layer_id if both are provided."
msgstr "(Optional) Comma-separated list of layer IDs. Takes precedence over layer_id if both are provided."

msgid "(Optional) Maximum number of tracks to display. Default: -1 (unlimited)."
msgstr "(Optional) Maximum number of tracks to display. Default: -1 (unlimited)."

msgid "(Optional) Display tracks in random order. Values: \"true\" or \"false\". Default: \"false\"."
msgstr "(Optional) Display tracks in random order. Values: \"true\" or \"false\". Default: \"false\"."

msgid "(Optional) Display layer content (title, subtitle, description, featured image). Values: true/false. Default: false."
msgstr "(Optional) Display layer content (title, subtitle, description, featured image). Values: true/false. Default: false."

msgid "(Optional) Use Elasticsearch API for advanced filtering. Values: \"true\" or \"false\". Default: \"true\"."
msgstr "(Optional) Use Elasticsearch API for advanced filtering. Values: \"true\" or \"false\". Default: \"true\"."

msgid "(Optional) Show filter interface (distance, region, difficulty, elevation). Values: \"true\" or \"false\". Default: \"true\"."
msgstr "(Optional) Show filter interface (distance, region, difficulty, elevation). Values: \"true\" or \"false\". Default: \"true\"."

msgid "Grid POIs page:"
msgstr "Grid POIs page:"

msgid "Shortcode to display a grid of POIs filtered by POI type taxonomy."
msgstr "Shortcode to display a grid of POIs filtered by POI type taxonomy."

msgid "(Optional) ID of a single POI type to display POIs from."
msgstr "(Optional) ID of a single POI type to display POIs from."

msgid "(Optional) Comma-separated list of POI type IDs. Takes precedence over poi_type_id if both are provided."
msgstr "(Optional) Comma-separated list of POI type IDs. Takes precedence over poi_type_id if both are provided."

msgid "(Optional) Maximum number of POIs to display. Default: -1 (unlimited)."
msgstr "(Optional) Maximum number of POIs to display. Default: -1 (unlimited)."

msgid "(Optional) Display POIs in random order. Values: \"true\" or \"false\". Default: \"false\"."
msgstr "(Optional) Display POIs in random order. Values: \"true\" or \"false\". Default: \"false\"."

