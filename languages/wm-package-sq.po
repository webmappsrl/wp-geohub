msgstr "Nuk mund të ndërtohej URL e Config API për këtë shard."

msgid "Config updated from API (WORDPRESS/APP merged with local when present)."
msgstr "Config u përditësua nga API (WORDPRESS/APP u bashkua me lokal kur është i pranishëm)."

msgid "Using local config (API unavailable or invalid response)."
msgstr "Duke përdorur config lokal (API e padisponueshme ose përgjigje e pavlefshme)."

msgid "Security verification failed. Please try again."
msgstr "Verifikimi i sigurisë dështoi. Ju lutemi provoni përsëri."

