msgstr "POIs u sinkronizuan me sukses!"

msgid "Unknown error occurred"
msgstr "Ndodhi një gabim i panjohur"

msgid "Error communicating with the server"
msgstr "Gabim në komunikim me serverin"

msgid "Request timeout. The operation may still be processing. Please check the results."
msgstr "Koha e kërkesës skadoi. Operacioni mund të jetë ende në procesim. Ju lutemi kontrolloni rezultatet."

msgid "Response format error, but operation may have completed. Please check the results."
msgstr "Gabim në formatin e përgjigjes, por operacioni mund të jetë përfunduar. Ju lutemi kontrolloni rezultatet."

msgid "Failed to refresh"
msgstr "Dështoi përditësimi"

