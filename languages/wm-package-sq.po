msgid "shards"
msgstr "shards"

msgid "Please select a PNG file first."
msgstr "Ju lutemi zgjidhni fillimisht një skedar PNG."

msgid "Synchronization session expired. Please start over."
msgstr "Sesioni i sinkronizimit ka skaduar. Ju lutemi filloni përsëri."

msgid "Synchronization session expired."
msgstr "Sesioni i sinkronizimit ka skaduar."

msgid "Stuck process detected. Synchronization has been stopped. Please start over."
msgstr "Procesi i bllokuar u zbulua. Sinkronizimi u ndal. Ju lutemi filloni përsëri."

msgid "Stuck process detected."
msgstr "Procesi i bllokuar u zbulua."

msgid "Global timeout reached (%d minutes). Synchronization has been stopped. Please start over."
msgstr "Koha globale e pritjes u arrit (%d minuta). Sinkronizimi u ndal. Ju lutemi filloni përsëri."

msgid "Global timeout reached."
msgstr "Koha globale e pritjes u arrit."

msgid "Too many consecutive errors (%d). Synchronization has been stopped to avoid an infinite loop."
msgstr "Shumë gabime të njëpasnjëshme (%d). Sinkronizimi u ndal për të shmangur një lak të pafund."

msgid "Too many consecutive errors."
msgstr "Shumë gabime të njëpasnjëshme."

msgid "Great! Tracks synchronized successfully."
msgstr "E shkëlqyer! Gjurmët u sinkronizuan me sukses."

msgid "Synchronization completed! Processed %d tracks."
msgstr "Sinkronizimi u përfundua! %d gjurmë të përpunuara."

msgid "Batch completed: %d/%d tracks (%d%%)"
msgstr "Grupi u përfundua: %d/%d gjurmë (%d%%)"

msgid "Processed"
msgstr "Të përpunuara"

msgid "Skipped"
msgstr "Të anashkaluara"

msgid "Errors"
msgstr "Gabime"

msgid "Time"
msgstr "Koha"

msgid "tracks"
msgstr "gjurmë"

msgid "Do you want to stop the synchronization?"
